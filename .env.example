# Spotify OAuth (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# NextAuth (Auth.js v5 also reads AUTH_SECRET, AUTH_URL)
NEXTAUTH_SECRET=          # required — generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Canonical site URL — must match Spotify “Redirect URIs” exactly (scheme + host + port + path).
# Local dev (Spotify blocks bare “localhost” for new apps):
AUTH_URL=http://127.0.0.1:3000
NEXTAUTH_URL=http://127.0.0.1:3000
# Production: public HTTPS origin for your deployed app (not loopback) — e.g.
# AUTH_URL=https://yourdomain.com
# NEXTAUTH_URL=https://yourdomain.com

# Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Supabase (https://supabase.com — project settings)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY= # server-only — never ship to the browser

# Internal shared secret used for the server-to-server scoring trigger
INTERNAL_SCORE_SECRET=     # generate: openssl rand -hex 24
